# 生产环境应用服务 Dockerfile
FROM eclipse-temurin:21-jre-alpine

WORKDIR /app

# 创建非root用户
RUN addgroup -S spring && adduser -S spring -G spring

# 创建必要的目录并设置权限
RUN mkdir -p /tmp/code_output /tmp/code_deploy /logs && \
    chown -R spring:spring /tmp/code_output /tmp/code_deploy /logs

USER spring:spring

# 复制构建好的jar文件
COPY app-service.jar app.jar

# 环境变量 - 使用 GitHub Secrets 或默认值
ENV SPRING_PROFILES_ACTIVE=docker
ENV JAVA_OPTS="-Xmx1024m -Xms512m -XX:+UseG1GC -XX:+ExitOnOutOfMemoryError"
ENV DB_HOST=${DB_HOST:-mysql}
ENV DB_PORT=${DB_PORT:-3306}
ENV DB_NAME=${DB_NAME:-ai_code_gen}
ENV DB_USER=${DB_USER:-ai_code_gen_user}
ENV DB_PASSWORD=${DB_PASSWORD:-12345678}
ENV REDIS_HOST=${REDIS_HOST:-redis}
ENV REDIS_PORT=${REDIS_PORT:-6379}
ENV NACOS_HOST=${NACOS_HOST:-nacos}
ENV NACOS_PORT=${NACOS_PORT:-8848}
ENV AI_DASHSCOPE_API_KEY=${AI_DASHSCOPE_API_KEY:-}
ENV DEEPSEEK_API_KEY=${DEEPSEEK_API_KEY:-}
ENV COS_SECRET_ID=${COS_SECRET_ID:-}
ENV COS_SECRET_KEY=${COS_SECRET_KEY:-}
ENV NODE_BUILDER_URL=${NODE_BUILDER_URL:-http://node-builder:8020/build}
ENV DEPLOY_HOST=${DEPLOY_HOST:-http://localhost}

# 暴露端口
EXPOSE 8126

# 健康检查
HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
  CMD wget --no-verbose --tries=1 --spider http://localhost:8126/actuator/health || exit 1

# 启动应用
ENTRYPOINT ["sh", "-c", "java ${JAVA_OPTS} -jar app.jar"]
