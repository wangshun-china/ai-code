# 本地开发环境变量配置
# 此配置用于本地开发模式，直接运行Spring Boot应用

# ============== 必需配置 ==============

# AI服务API密钥（必需）
# 阿里云DashScope API密钥：https://help.aliyun.com/zh/dashscope/developer-reference/activate-dashscope-and-create-an-api-key
AI_DASHSCOPE_API_KEY=sk-814d2907354744f4a69661e19ab043bc

# DeepSeek API密钥（可选，备用）
# 获取地址：https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# ============== 数据库配置（Docker MySQL容器） ==============
# 使用Docker Compose中的MySQL容器
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ai_code_gen
DB_USER=root
DB_PASSWORD=root123456

# ============== Redis配置（本地安装的Redis） ==============
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ============== Nacos配置（本地开发通常不需要Nacos） ==============
# 本地开发模式直接连接，不需要Nacos服务发现
NACOS_HOST=localhost
NACOS_PORT=8848

# ============== 腾讯云COS配置（可选） ==============
COS_SECRET_ID=AKIDsb9W0YDk6rTwHWVLAp3867FsLgseSwGR
COS_SECRET_KEY=EJDwWvGRQDrTchhnmdaftz374ogvBILD
COS_REGION=ap-nanjing
COS_BUCKET=xixibox-blog-pic-1313495082
COS_HOST=https://xixibox-blog-pic-1313495082.cos.ap-nanjing.myqcloud.com

# ============== 部署域名配置 ==============
# 本地开发使用localhost
DEPLOY_HOST=http://localhost:8123

# ============== Node构建器服务地址 ==============
# 本地开发模式不需要Node构建器，或使用本地Node环境
NODE_BUILDER_URL=http://localhost:3000/build

# ============== Java应用内存设置 ==============
JAVA_OPTS="-Xmx2g -Xms1g -Xss4m -XX:+UseG1GC"

# ============== 前端环境变量（开发时使用） ==============
# 前端开发服务器配置
# 使用相对路径，由Vite代理转发到后端
VITE_API_BASE_URL=/api
VITE_DEPLOY_DOMAIN=http://localhost

# ============== Spring Profile配置 ==============
# 本地开发使用local profile
SPRING_PROFILES_ACTIVE=local

# ============== 开发工具配置 ==============
# 启用Spring Boot DevTools热部署
spring.devtools.restart.enabled=true
spring.devtools.restart.poll-interval=2s
spring.devtools.restart.quiet-period=1s