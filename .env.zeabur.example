# Zeabur 部署环境变量配置示例
# 复制此文件为 .env.zeabur 并填写实际值

# 数据库配置（如果使用Zeabur的MySQL服务）
DB_HOST=your-mysql-service.zeabur.internal
DB_PORT=3306
DB_NAME=yu_ai_code_mother
DB_USER=root
DB_PASSWORD=your-mysql-password

# Redis配置（如果使用Zeabur的Redis服务）
REDIS_HOST=your-redis-service.zeabur.internal
REDIS_PORT=6379
REDIS_PASSWORD=

# Nacos配置（如果使用自建Nacos，Zeabur可能不支持，建议使用容器）
NACOS_HOST=nacos
NACOS_PORT=8848

# AI服务API密钥
AI_DASHSCOPE_API_KEY=your-dashscope-api-key
DEEPSEEK_API_KEY=your-deepseek-api-key

# 腾讯云COS配置（可选）
COS_SECRET_ID=your-cos-secret-id
COS_SECRET_KEY=your-cos-secret-key
COS_REGION=ap-shanghai
COS_BUCKET=your-bucket-name
COS_HOST=your-cos-domain.com

# 部署域名（Zeabur提供的域名）
DEPLOY_HOST=https://your-project.zeabur.app

# Node构建器服务地址（在Zeabur中需要使用服务发现）
NODE_BUILDER_URL=http://node-builder:3000/build

# Java应用内存设置
JAVA_OPTS=-Xmx512m -Xms256m

# 前端环境变量（构建时使用）
VITE_API_BASE_URL=/api
VITE_DEPLOY_DOMAIN=/deploy