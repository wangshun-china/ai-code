# 本地WSL2部署环境变量配置
# 复制此文件为 .env 并填写实际值

# ============== 必需配置 ==============

# AI服务API密钥（必需）
# 阿里云DashScope API密钥：https://help.aliyun.com/zh/dashscope/developer-reference/activate-dashscope-and-create-an-api-key
AI_DASHSCOPE_API_KEY=sk-814d2907354744f4a69661e19ab043bc

# DeepSeek API密钥（可选，备用）
# 获取地址：https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# ============== 数据库配置（使用Docker Compose中的MySQL） ==============
DB_HOST=mysql
DB_PORT=3306
DB_NAME=yu_ai_code_mother
DB_USER=yu_ai_code_mother_user
DB_PASSWORD=12345678

# ============== Redis配置（使用Docker Compose中的Redis） ==============
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ============== Nacos配置（使用Docker Compose中的Nacos） ==============
NACOS_HOST=nacos
NACOS_PORT=8848

# ============== 腾讯云COS配置（可选，用于截图上传） ==============
# 如果不配置，截图功能可能无法正常工作
COS_SECRET_ID=AKIDsb9W0YDk6rTwHWVLAp3867FsLgseSwGR
COS_SECRET_KEY=EJDwWvGRQDrTchhnmdaftz374ogvBILD
COS_REGION=ap-nanjing
COS_BUCKET=xixibox-blog-pic-1313495082
COS_HOST=https://xixibox-blog-pic-1313495082.cos.ap-nanjing.myqcloud.com

# ============== 部署域名配置 ==============
# 本地部署使用localhost，外部访问时使用实际IP或域名
DEPLOY_HOST=http://localhost

# ============== Dubbo服务主机配置 ==============
# Dubbo服务注册时使用的主机地址，本地部署使用localhost
DUBBO_HOST=localhost

# ============== Node构建器服务地址 ==============
# Docker Compose内部服务发现
NODE_BUILDER_URL=http://node-builder:3000/build

# ============== Java应用内存设置 ==============
# 根据服务器内存调整，建议总值不超过物理内存的70%
JAVA_OPTS="-Xmx4g -Xms2g -Xss4m -XX:+UseG1GC -XX:+ExitOnOutOfMemoryError -XX:+HeapDumpOnOutOfMemoryError"

# ============== Spring Profile配置 ==============
# 本地部署使用docker profile
SPRING_PROFILES_ACTIVE=docker

# ============== 前端环境变量（构建时使用） ==============
# 这些变量在前端构建时注入，修改后需要重新构建前端
VITE_API_BASE_URL=/api
VITE_DEPLOY_DOMAIN=/deploy

# ============== 高级配置（可选） ==============
# Spring AI配置
# SPRING_AI_OPENAI_API_KEY=your-openai-key
# SPRING_AI_OPENAI_BASE_URL=https://api.openai.com/v1

# 邮件服务配置（如果启用了邮件功能）
# SPRING_MAIL_HOST=smtp.gmail.com
# SPRING_MAIL_PORT=587
# SPRING_MAIL_USERNAME=your-email@gmail.com
# SPRING_MAIL_PASSWORD=your-app-password
